<?xml version="1.0"?>
<robot name="hunter_se"
    xmlns:xacro="http://ros.org/wiki/xacro">

    <xacro:include filename="$(find hunter_se_description)/urdf/lidar_3d.xacro"/>

    <!-- ===================== Base ===================== -->
    <link name="base_link">
        <inertial>
            <origin xyz="0.0374140021041951 -0.000373005187591258 -0.0771282894414029" rpy="0 0 0"/>
            <mass value="24.73"/>
            <inertia ixx="0.123215829336501" ixy="-2.51201031615063E-06" ixz="0.00480100638469038"
                     iyy="0.219144715482931" iyz="-1.0329581476775E-05" izz="0.313606030126045"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/base_link.STL"/>
            </geometry>
            <material name="base_material">
                <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/base_link.STL"/>
            </geometry>
        </collision>
    </link>

    <!-- ===================== Front-left steer + wheel ===================== -->
    <link name="fr_steer_left_link">
        <inertial>
            <origin xyz="-0.0002776492198312 0.0163539773588368 4.97346169803237E-09" rpy="0 0 0"/>
            <mass value="3.149"/>
            <inertia ixx="0.0222" ixy="0.0" ixz="0.0" iyy="0.0222" iyz="0.0" izz="0.0378075"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.001 0.001 0.001"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.001 0.001 0.001"/></geometry>
        </collision>
    </link>
    <joint name="fr_steer_left_joint" type="revolute">
        <origin xyz="0.34058 0.24619 -0.1535" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="fr_steer_left_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.384" upper="0.384" effort="100" velocity="5"/>
    </joint>

    <link name="fr_left_link">
        <inertial>
            <origin xyz="-3.5837499634539E-10 4.97346158701006E-09 -0.016356334080185" rpy="0 0 0"/>
            <mass value="3.149"/>
            <inertia ixx="0.0222" ixy="0.0" ixz="0.0" iyy="0.0222" iyz="0.0" izz="0.0378075"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/fr_left_link.STL"/>
            </geometry>
            <material name="wheel_material">
                <color rgba="0.223529411764706 0.223529411764706 0.223529411764706 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/fr_left_link.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="fr_left_joint" type="continuous">
        <origin xyz="0 0 0" rpy="1.5708 0 0.016976"/>
        <parent link="fr_steer_left_link"/>
        <child link="fr_left_link"/>
        <axis xyz="0 0 -1"/>
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <!-- ===================== Front-right steer + wheel ===================== -->
    <link name="fr_steer_right_link">
        <inertial>
            <origin xyz="0.000274981985673328 -0.0163540222836661 -3.24802407192237E-11" rpy="0 0 0"/>
            <mass value="3.149"/>
            <inertia ixx="0.0222" ixy="0.0" ixz="0.0" iyy="0.0222" iyz="0.0" izz="0.0378075"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.001 0.001 0.001"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.001 0.001 0.001"/></geometry>
        </collision>
    </link>
    <joint name="fr_steer_right_joint" type="revolute">
        <origin xyz="0.34219 -0.24619 -0.1535" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="fr_steer_right_link"/>
        <axis xyz="0 0 1"/>
        <limit lower="-0.384" upper="0.384" effort="100" velocity="5"/>
    </joint>

    <link name="fr_right_link">
        <inertial>
            <origin xyz="0.00027498198567355 3.24801296969213E-11 -0.0163540222836661" rpy="0 0 0"/>
            <mass value="3.149"/>
            <inertia ixx="0.0222" ixy="0.0" ixz="0.0" iyy="0.0222" iyz="0.0" izz="0.0378075"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/fr_right_link.STL"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/fr_right_link.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="fr_right_joint" type="continuous">
        <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
        <parent link="fr_steer_right_link"/>
        <child link="fr_right_link"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <!-- ===================== Rear-left driven wheel ===================== -->
    <link name="re_left_link">
        <inertial>
            <origin xyz="1.245E-09 1.7252E-06 -0.010284" rpy="0 0 0"/>
            <mass value="3.149"/>
            <inertia ixx="0.0222" ixy="0.0" ixz="0.0" iyy="0.0222" iyz="0.0" izz="0.0378075"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/re_left_link.STL"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/re_left_link.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="re_left_joint" type="continuous">
        <origin xyz="-0.2078 0.252 -0.158" rpy="1.5708 0 0"/>
        <parent link="base_link"/>
        <child link="re_left_link"/>
        <axis xyz="0 0 -1"/>
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <!-- ===================== Rear-right driven wheel ===================== -->
    <link name="re_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="3.149"/>
            <inertia ixx="0.0222" ixy="0.0" ixz="0.0" iyy="0.0222" iyz="0.0" izz="0.0378075"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/re_right_link.STL"/>
            </geometry>
            <material name="wheel_material"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://hunter_se_description/meshes/re_right_link.STL"/>
            </geometry>
        </collision>
    </link>
    <joint name="re_right_joint" type="continuous">
        <origin xyz="-0.2078 -0.252 -0.158" rpy="-1.5708 0 0"/>
        <parent link="base_link"/>
        <child link="re_right_link"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.0" friction="0.1"/>
    </joint>

    <!-- ===================== Wheel surface friction ===================== -->
    <gazebo reference="fr_left_link">
        <mu1>0.8</mu1><mu2>0.8</mu2><kp>500000.0</kp><kd>10.0</kd>
        <minDepth>0.001</minDepth><maxVel>0.1</maxVel><fdir1>1 0 0</fdir1>
    </gazebo>
    <gazebo reference="fr_right_link">
        <mu1>0.8</mu1><mu2>0.8</mu2><kp>500000.0</kp><kd>10.0</kd>
        <minDepth>0.001</minDepth><maxVel>0.1</maxVel><fdir1>1 0 0</fdir1>
    </gazebo>
    <gazebo reference="re_left_link">
        <mu1>0.8</mu1><mu2>10</mu2><kp>500000.0</kp><kd>10.0</kd>
        <minDepth>0.001</minDepth><maxVel>0.1</maxVel><fdir1>1 0 0</fdir1>
    </gazebo>
    <gazebo reference="re_right_link">
        <mu1>0.8</mu1><mu2>10</mu2><kp>500000.0</kp><kd>10.0</kd>
        <minDepth>0.001</minDepth><maxVel>0.1</maxVel><fdir1>1 0 0</fdir1>
    </gazebo>

    <!-- ===================== Gazebo (gz-sim) plugins ===================== -->
    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
            <update_rate>50</update_rate>
            <joint_name>fr_steer_left_joint</joint_name>
            <joint_name>fr_steer_right_joint</joint_name>
            <joint_name>fr_left_joint</joint_name>
            <joint_name>fr_right_joint</joint_name>
            <joint_name>re_left_joint</joint_name>
            <joint_name>re_right_joint</joint_name>
        </plugin>

        <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
            <left_steering_joint>fr_steer_left_joint</left_steering_joint>
            <right_steering_joint>fr_steer_right_joint</right_steering_joint>
            <left_joint>re_left_joint</left_joint>
            <right_joint>re_right_joint</right_joint>
            <wheel_separation>0.504</wheel_separation>
            <kingpin_width>0.49238</kingpin_width>
            <wheel_base>0.5492</wheel_base>
            <wheel_radius>0.1375</wheel_radius>
            <topic>cmd_vel</topic>
            <steering_limit>0.384</steering_limit>
            <max_velocity>1.33</max_velocity>
            <min_acceleration>-3.0</min_acceleration>
            <max_acceleration>3.0</max_acceleration>
        </plugin>

        <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_link</robot_base_frame>
            <odom_publish_frequency>50</odom_publish_frequency>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <dimensions>2</dimensions>
        </plugin>
    </gazebo>

    <xacro:lidar_3d parent="base_link"/>
</robot>
